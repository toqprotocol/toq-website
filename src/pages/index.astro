---
import '../styles/global.css';
import Hero from '../components/hero.tsx';
---
<html lang="en" style="overflow:hidden;height:100vh;">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>toq protocol</title>
  <meta name="description" content="The open protocol for secure agent-to-agent communication" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <meta property="og:title" content="toq protocol" />
  <meta property="og:description" content="The open protocol for secure agent-to-agent communication" />
  <meta property="og:image" content="https://toq.dev/og.png" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://toq.dev" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://toq.dev/og.png" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
</head>
<body style="margin:0;padding:0;height:100vh;overflow:hidden;overscroll-behavior:none;background:#000;">
  <Hero client:load />
  <script is:inline>
    if(sessionStorage.getItem("toq-fade-in-home")){sessionStorage.removeItem("toq-fade-in-home");document.body.style.opacity="0";document.body.style.background="#fff";document.body.style.transition="opacity 0.4s ease-in-out";requestAnimationFrame(()=>{requestAnimationFrame(()=>{document.body.style.opacity="1"})})}
  </script>
</body>
</html>
